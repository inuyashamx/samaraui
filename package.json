{
  "name": "samaraui",
  "version": "0.3.0",
  "description": "A web UI for Claude Code - chat with agents and preview their work in real-time",
  "main": "server/index.ts",
  "type": "module",
  "bin": {
    "samaraui": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "server/",
    "shared/",
    "public/app/dist/",
    "public/app/package.json"
  ],
  "scripts": {
    "dev": "concurrently \"tsx server/index.ts\" \"cd public/app && npx vite\"",
    "build": "cd public/app && npm install && npm run build",
    "prepublishOnly": "npm run build",
    "start": "tsx server/index.ts"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "agent",
    "ui",
    "ide"
  ],
  "author": "InuYashaMX",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inuyashamx/samaraui.git"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "typescript": "^5.8.0",
    "@types/express": "^5.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "commander": "^13.1.0",
    "express": "^5.1.0",
    "open": "^10.1.0",
    "playwright": "^1.58.2",
    "socket.io": "^4.8.0",
    "tsx": "^4.19.0"
  }
}
